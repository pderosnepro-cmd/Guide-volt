# DBBackupManager - Git Ignore

# Environnements virtuels
*/
!DBBackupManager/
venv/
ENV/
env/
.venv/

# Fichiers Python compilés
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer les dépendances
install/

# Fichiers de configuration locaux
config/local_config.json
config/*.local.json

# Fichiers de sauvegarde
backups/

# Journaux
logs/
*.log

# Fichiers temporaires
*.tmp
*.temp
*.swp
*~

# IDE
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# OS
.DS_Store
Thumbs.db

# Fichiers de test
*.test
*.spec

# Fichiers de données sensibles
*.env
.env.local
.env.*.local

# Clés de chiffrement (ne jamais commiter !)
*.key
*.pem
*.crt
*.cer

# Fichiers de base de données SQLite
*.sqlite
*.db
*.sqlite3

# Fichiers de sauvegarde temporaires
*.bak
*.backup

# Fichiers générés par l'IDE
*.pydevproject
*.settings/
